# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories
# vendor/

# Go workspace file
go.work
go.work.sum

# env files (secrets)
.env
.env.*

# MacOS
.DS_Store

# Go IDE / Editor folders
.idea/
.vscode/

# Build artifacts / Executables
# (On macOS/Linux, go build often produces binaries without extensions)
bin/
main
app
server

# Compiled tutorial output
*/main
*/*.exe

# If an executable inherits the folder name (e.g. 01_basic produces an executable named 01_basic)
[0-1][0-9]_*/[0-1][0-9]_*

